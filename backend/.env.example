# DATABASE — no Railway, o plugin Postgres injeta DATABASE_URL automaticamente
DATABASE_URL=postgresql://postgres:senha@localhost:5432/hospitalar360

# SERVER
API_PORT=3001
NODE_ENV=development

# JWT (usado na Parte B — auth real). Gere uma chave longa e aleatória.
JWT_SECRET=troque_por_uma_chave_super_secreta_com_no_minimo_32_caracteres

# CORS — origens permitidas (separadas por vírgula). Em produção, a URL do front.
# Subdomínios *.verificadoagora.com.br e *.vercel.app já são liberados pelo código.
CORS_ORIGIN=http://localhost:3000
